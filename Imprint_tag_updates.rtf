Semiconductors\
Security\
Fintech\
Healthcare\
Energy\
Industrial\
Consumer\
Macro\
Government\
Geopolitics\
\
\pard\pardeftab720\sa240\partightenfactor0

\f0\b\fs24 \cf0 Examples
\f1\b0 \
\pard\pardeftab720\partightenfactor0

\f3\fs26 \cf0 \
sector: Semiconductors\
