\outl0\strokewidth0 \strokec2 search results\
\ls2\ilvl0\kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 digest generation\
\ls2\ilvl0\kerning1\expnd0\expndtw0 \outl0\strokewidth0 {\listtext	\uc0\u8226 	}\expnd0\expndtw0\kerning0
\outl0\strokewidth0 \strokec2 pattern detection across documents\
\pard\pardeftab720\sa240\partightenfactor0

\f0\b \cf0 Guidelines
\f1\b0 \
